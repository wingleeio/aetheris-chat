{
    "name": "aetheris-chat",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "tsx watch ./src/index.ts",
        "build:server": "yarn tsc --project tsconfig.server.json && tsc-alias --project tsconfig.server.json",
        "build:next": "next build",
        "build": "yarn build:server && yarn build:next",
        "start": "NODE_ENV=production node ./dist/index.js",
        "lint": "next lint",
        "database:generate": "npx @edgedb/generate queries --file"
    },
    "dependencies": {
        "@aetheris/client": "^0.0.13",
        "@aetheris/react-query": "^0.0.13",
        "@aetheris/server": "^0.0.13",
        "@tanstack/react-query": "^5.48.0",
        "dotenv": "^16.4.5",
        "edgedb": "^1.5.7",
        "lucia": "^3.2.0",
        "next": "14.2.4",
        "pino": "^9.2.0",
        "pino-pretty": "^11.2.1",
        "react": "^18",
        "react-dom": "^18",
        "resend": "^3.4.0",
        "ws": "^8.17.1",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/node": "^20",
        "@types/react": "^18",
        "@types/react-dom": "^18",
        "@types/ws": "^8.5.10",
        "postcss": "^8",
        "tailwindcss": "^3.4.1",
        "tsc-alias": "^1.8.10",
        "tsconfig-paths": "^4.2.0",
        "tsx": "^4.15.7",
        "typescript": "^5"
    }
}
